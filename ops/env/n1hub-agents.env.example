NODE_ENV=production

# Shared app/API auth for protected N1Hub routes.
N1HUB_AUTH_TOKEN=replace-with-a-long-random-token

# Strongly recommended for production so AI Wallet secrets remain decryptable
# across process restarts and host-level service restarts.
N1HUB_AI_WALLET_KEY=replace-with-a-long-random-wallet-key

# Required for the Linear-backed Symphony lane.
LINEAR_API_KEY=
LINEAR_PROJECT_SLUG=

# Optional for the Claude Subscription bridge slot in the AI Wallet.
# Use the full endpoint URL that should receive the generation POST.
N1HUB_CLAUDE_SUBSCRIPTION_BASE_URL=

# Optional for the ChatGPT / Codex Subscription bridge slot in the AI Wallet.
# Use the full endpoint URL that should receive the generation POST.
N1HUB_CODEX_SUBSCRIPTION_BASE_URL=

# Optional when using the `n1_subscription` provider slot in the AI Wallet.
N1HUB_N1_SUBSCRIPTION_BASE_URL=

# Optional Gemini fallback for trusted local or host-level bring-up.
# If set, N1Hub can use Gemini even before the key is stored in AI Wallet.
GEMINI_API_KEY=

# Optional override for Gemini REST base URL.
GEMINI_API_BASE_URL=

# Optional GitHub Models fallback for trusted local or host-level bring-up.
# Either GITHUB_MODELS_TOKEN or GITHUB_TOKEN may be used.
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_BASE_URL=
