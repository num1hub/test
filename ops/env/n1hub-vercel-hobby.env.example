# Vercel Hobby locked-owner deployment
# Copy these values into the Vercel project env UI. Do not commit real secrets.

NODE_ENV=production

# Signed session secret for middleware / cookie auth.
N1HUB_AUTH_SECRET=replace-with-a-long-random-secret

# Exact owner login accepted by /api/auth.
N1HUB_OWNER_LOGIN=egor-n1

# Env-backed owner password for Hobby mode.
VAULT_PASSWORD=replace-with-a-strong-password

# Short private access code required alongside the password.
N1HUB_ACCESS_CODE=n1x1

# Secret route segment. The effective route becomes:
# /architect-gate/<N1HUB_OWNER_ROUTE_SEGMENT>
N1HUB_OWNER_ROUTE_SEGMENT=replace-with-a-secret-route-segment
