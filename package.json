{
  "name": "n1hub.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:anchors": "vitest run --config vitest.anchors.config.ts",
    "test:e2e": "playwright test",
    "validate": "tsx scripts/validate-cli.ts",
    "validate:all": "tsx scripts/validate-cli.ts --dir data/capsules --strict --report",
    "symphony": "tsx scripts/symphony.ts",
    "ninfinity": "tsx scripts/ninfinity.ts",
    "vault-steward": "tsx scripts/vault-steward.ts",
    "a2c:activate": "tsx scripts/a2c/activate.ts --require-ready",
    "a2c:recon": "tsx scripts/a2c/recon.ts --workspace-root . --kb-root .",
    "a2c:index": "tsx scripts/a2c/index.ts --kb-root .",
    "a2c:status": "tsx scripts/a2c/status.ts --kb-root . --json",
    "a2c:voids": "tsx scripts/a2c/void.ts",
    "a2c:weave": "tsx scripts/a2c/weave.ts",
    "a2c:watch:once": "tsx scripts/a2c/watch.ts --once --dry-run",
    "a2c:cron:once": "tsx scripts/a2c/cron.ts --once",
    "a2c:audit": "tsx scripts/a2c/audit.ts --expected-dialect n1hub",
    "a2c:query": "tsx scripts/a2c/query.ts",
    "a2c:ingest": "tsx scripts/a2c/ingest.ts",
    "a2c:auto": "tsx scripts/a2c/autonomous.ts --dry-run",
    "a2c:daemon:watch": "tsx scripts/a2c/watch.ts",
    "a2c:investigate": "tsx scripts/a2c/investigate.ts",
    "a2c:audit:py": "echo deprecated: use npm run a2c:audit",
    "curate:a2c-runtime": "tsx scripts/curate-a2c-runtime-capsules.ts",
    "curate:a2c-temp": "tsx scripts/curate-a2c-temp-assimilation.ts",
    "migrate:projects": "tsx scripts/migrate-projects.ts",
    "migrate:branches": "tsx scripts/migrate-branches.ts",
    "validate-staged": "node scripts/validate-staged-capsules.js",
    "audit:capsules": "tsx scripts/audit-capsules.ts",
    "audit:file-guardrails": "tsx scripts/check-file-guardrails.ts",
    "check:file-guardrails:hard": "tsx scripts/check-file-guardrails.ts --fail-on-hard",
    "extract:anchors": "tsx scripts/extract-anchors.ts",
    "validate:anchors": "tsx scripts/validate-anchors.ts",
    "verify:root-docs": "tsx scripts/verify-root-docs.ts",
    "anchors:coverage": "tsx scripts/analyze-coverage.ts --out=.anchors-coverage.json",
    "anchors:kpis": "tsx scripts/report-kpis.ts",
    "anchors:intelligence": "tsx scripts/anchors-intelligence.ts --out=.anchors-intelligence.json",
    "anchors:scorecard": "tsx scripts/anchors-scorecard.ts --out=.anchors-scorecard.json --thresholds=anchor-governance.thresholds.json",
    "anchors:assert-scorecard": "tsx scripts/assert-scorecard.ts .anchors-scorecard.json",
    "anchors:lint-usage": "tsx scripts/lint-anchors-usage.ts",
    "terminology:lint": "tsx scripts/terminology-lint.ts",
    "anchors:snapshot": "tsx scripts/anchors-snapshot.ts --scorecard=.anchors-scorecard.json --out=.anchors-history.jsonl",
    "check:anchors": "npm run extract:anchors && npm run validate:anchors && npm run verify:root-docs && npm run test:anchors",
    "check:anchors:full": "npm run check:anchors && npm run anchors:coverage && npm run anchors:kpis && npm run anchors:intelligence && npm run anchors:scorecard && npm run anchors:assert-scorecard && npm run anchors:lint-usage && npm run terminology:lint && npm run anchors:snapshot && npm run typecheck",
    "docs:openapi": "tsx scripts/generate-validate-openapi.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "canonical-json": "^0.2.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "liquidjs": "^10.24.0",
    "lucide-react": "^0.540.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-force-graph-2d": "^1.29.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0",
    "msw": "^2.12.10",
    "playwright": "^1.56.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
